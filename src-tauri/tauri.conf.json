{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Symphony",
  "version": "0.1.0",
  "identifier": "app.symphony.desktop",
  "build": {
    "beforeBuildCommand": "npm run build:desktop:prepare",
    "frontendDist": "../desktop-static"
  },
  "app": {
    "windows": [
      {
        "title": "Symphony Desktop",
        "width": 1320,
        "height": 860,
        "minWidth": 980,
        "minHeight": 680,
        "visible": false,
        "url": "index.html"
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; connect-src 'self' http://127.0.0.1:*"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": [
      "resources"
    ],
    "icon": [
      "icons/icon.png"
    ]
  }
}
