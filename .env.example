# Symphony startup environment variables
# Copy to .env and fill values for your local setup.

# Required for live tracker mode (non-offline) when tracker.kind=linear:
LINEAR_API_KEY=

# Required for live tracker mode (non-offline) when tracker.kind=github:
GITHUB_TOKEN=

# Optional startup behavior:
SYMPHONY_OFFLINE=0
SYMPHONY_PORT=3000
SYMPHONY_WORKFLOW_PATH=./WORKFLOW.md

# Optional Codex runtime overrides (used by WORKFLOW.md codex.command):
# - Switch account/credits by changing SYMPHONY_CODEX_HOME
# - Keep these local in .env/.env.local (do not commit secrets)
SYMPHONY_CODEX_HOME=
SYMPHONY_CODEX_MODEL=
SYMPHONY_CODEX_REASONING=
SYMPHONY_CODEX_FLAGS=

# In tutorials, switch tracker mode by updating WORKFLOW.md tracker.kind
# and setting the matching token above.

# Optional custom env-file path override (advanced):
# SYMPHONY_ENV_FILE=./.env
