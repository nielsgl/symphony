{
  "name": "symphony",
  "version": "0.1.0",
  "private": true,
  "description": "Symphony workflow config pipeline",
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "test": "vitest run",
    "start:dashboard": "npm run build && node scripts/start-dashboard.js",
    "start:api": "npm run start:dashboard",
    "start:web": "npm run start:dashboard",
    "start:desktop": "npm run build && electron desktop/main.js"
  },
  "dependencies": {
    "js-yaml": "^4.1.1",
    "liquidjs": "^10.25.5"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.19.17",
    "electron": "^41.2.0",
    "typescript": "^5.9.3",
    "vitest": "^2.1.9"
  }
}
