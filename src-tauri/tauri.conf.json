{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Symphony",
  "version": "0.1.0",
  "identifier": "app.symphony.desktop",
  "build": {
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../desktop-static"
  },
  "app": {
    "windows": [
      {
        "title": "Symphony Desktop",
        "width": 1320,
        "height": 860,
        "minWidth": 980,
        "minHeight": 680,
        "visible": false,
        "url": "index.html"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.png"
    ]
  }
}
